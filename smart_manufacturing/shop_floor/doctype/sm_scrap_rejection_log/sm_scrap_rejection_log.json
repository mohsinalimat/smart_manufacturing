{
  "name": "SM Scrap Rejection Log",
  "module": "Shop Floor",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "SCR-.YYYY.-.#####",
  "title_field": "item_code",
  "quick_entry": 1,
  "fields": [
    {"fieldname": "work_order",        "fieldtype": "Link",    "options": "Work Order","label": "Work Order","reqd": 1, "in_list_view": 1},
    {"fieldname": "job_card",          "fieldtype": "Link",    "options": "Job Card", "label": "Job Card",             "in_list_view": 1},
    {"fieldname": "col_break_1",       "fieldtype": "Column Break"},
    {"fieldname": "item_code",         "fieldtype": "Link",    "options": "Item",     "label": "Item",      "reqd": 1, "in_list_view": 1},
    {"fieldname": "workstation",       "fieldtype": "Link",    "options": "Workstation","label": "Workstation"},
    {"fieldname": "section_qty",       "fieldtype": "Section Break", "label": "Quantities"},
    {"fieldname": "scrap_qty",         "fieldtype": "Float",   "label": "Scrap Qty",  "reqd": 1, "in_list_view": 1},
    {"fieldname": "uom",               "fieldtype": "Link",    "options": "UOM",      "label": "UOM"},
    {"fieldname": "col_break_2",       "fieldtype": "Column Break"},
    {"fieldname": "rejection_type",    "fieldtype": "Select",  "label": "Rejection Type",
      "options": "Scrap\nRework\nReturn to Vendor\nQuarantine", "in_list_view": 1},
    {"fieldname": "defect_code",       "fieldtype": "Data",    "label": "Defect Code"},
    {"fieldname": "defect_description","fieldtype": "Small Text","label": "Defect Description"},
    {"fieldname": "section_cost",      "fieldtype": "Section Break", "label": "Cost Impact"},
    {"fieldname": "scrap_value",       "fieldtype": "Currency","label": "Scrap Value",  "read_only": 1},
    {"fieldname": "col_break_3",       "fieldtype": "Column Break"},
    {"fieldname": "salvage_value",     "fieldtype": "Currency","label": "Salvage Value"},
    {"fieldname": "operator",          "fieldtype": "Link",    "options": "Employee", "label": "Operator"}
  ],
  "permissions": [
    {"role": "SM Admin",              "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Shop Floor Operator","read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Production Manager", "read": 1, "write": 1},
    {"role": "SM Quality Inspector",  "read": 1, "write": 1},
    {"role": "SM Viewer",             "read": 1}
  ]
}
