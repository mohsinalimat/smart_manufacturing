{
  "name": "SM Downtime Log",
  "module": "Shop Floor",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "DT-.YYYY.-.#####",
  "title_field": "workstation",
  "quick_entry": 1,
  "fields": [
    {"fieldname": "workstation",       "fieldtype": "Link",     "options": "Workstation","label": "Workstation","reqd": 1, "in_list_view": 1},
    {"fieldname": "work_order",        "fieldtype": "Link",     "options": "Work Order", "label": "Work Order", "in_list_view": 1},
    {"fieldname": "col_break_1",       "fieldtype": "Column Break"},
    {"fieldname": "downtime_type",     "fieldtype": "Select",   "label": "Downtime Type",
      "options": "Planned\nUnplanned\nBreakdown\nChangeover\nQuality Issue\nMaterial Shortage\nOther",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "from_time",         "fieldtype": "Datetime", "label": "From",         "reqd": 1},
    {"fieldname": "to_time",           "fieldtype": "Datetime", "label": "To"},
    {"fieldname": "downtime_minutes",  "fieldtype": "Float",    "label": "Downtime (mins)","read_only": 1, "in_list_view": 1},
    {"fieldname": "section_cause",     "fieldtype": "Section Break", "label": "Root Cause"},
    {"fieldname": "cause_category",    "fieldtype": "Select",   "label": "Cause Category",
      "options": "\nMachine Failure\nOperator Error\nMaterial Issue\nPower Failure\nScheduled Maintenance\nSetup/Changeover\nOther"},
    {"fieldname": "col_break_2",       "fieldtype": "Column Break"},
    {"fieldname": "cause_description", "fieldtype": "Small Text","label": "Cause Description"},
    {"fieldname": "reported_by",       "fieldtype": "Link",     "options": "Employee",   "label": "Reported By"},
    {"fieldname": "corrective_action", "fieldtype": "Small Text","label": "Corrective Action"}
  ],
  "permissions": [
    {"role": "SM Admin",             "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Shop Floor Operator","read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Production Manager","read": 1, "write": 1},
    {"role": "SM Viewer",            "read": 1}
  ]
}
