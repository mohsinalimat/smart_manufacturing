{
  "name": "SM Shift Log",
  "module": "Shop Floor",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "SL-.YYYY.-.#####",
  "fields": [
    {
      "fieldname": "shift",
      "fieldtype": "Data",
      "label": "Shift",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "workstation",
      "fieldtype": "Link",
      "options": "Workstation",
      "label": "Workstation",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "shift_date",
      "fieldtype": "Date",
      "label": "Shift Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "supervisor",
      "fieldtype": "Link",
      "options": "Employee",
      "label": "Supervisor"
    },
    {
      "fieldname": "section_production",
      "fieldtype": "Section Break",
      "label": "Production Summary"
    },
    {
      "fieldname": "planned_qty",
      "fieldtype": "Float",
      "label": "Planned Qty"
    },
    {
      "fieldname": "actual_qty",
      "fieldtype": "Float",
      "label": "Actual Qty",
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "scrap_qty",
      "fieldtype": "Float",
      "label": "Scrap Qty"
    },
    {
      "fieldname": "downtime_minutes",
      "fieldtype": "Float",
      "label": "Total Downtime (mins)",
      "read_only": 1
    },
    {
      "fieldname": "efficiency_pct",
      "fieldtype": "Percent",
      "label": "Efficiency (%)",
      "read_only": 1
    },
    {
      "fieldname": "oee",
      "fieldtype": "Percent",
      "label": "OEE (%)",
      "read_only": 1
    },
    {
      "fieldname": "section_notes",
      "fieldtype": "Section Break",
      "label": "Notes"
    },
    {
      "fieldname": "shift_remarks",
      "fieldtype": "Text Editor",
      "label": "Shift Remarks"
    }
  ],
  "permissions": [
    {
      "role": "SM Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "SM Production Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "SM Shop Floor Operator",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "SM Viewer",
      "read": 1
    }
  ]
}