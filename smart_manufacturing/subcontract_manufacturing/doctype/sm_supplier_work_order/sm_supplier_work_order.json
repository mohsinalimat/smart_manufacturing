{
  "name": "SM Supplier Work Order",
  "module": "Subcontract Manufacturing",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "SWO-.YYYY.-.#####",
  "title_field": "supplier",
  "fields": [
    {"fieldname": "supplier",          "fieldtype": "Link",    "options": "Supplier", "label": "Supplier",    "reqd": 1, "in_list_view": 1},
    {"fieldname": "subcontracting_order","fieldtype": "Link",  "options": "Subcontracting Order","label": "Subcontracting Order"},
    {"fieldname": "col_break_1",       "fieldtype": "Column Break"},
    {"fieldname": "item_code",         "fieldtype": "Link",    "options": "Item",     "label": "Item",        "reqd": 1, "in_list_view": 1},
    {"fieldname": "qty",               "fieldtype": "Float",   "label": "Qty",        "reqd": 1, "in_list_view": 1},
    {"fieldname": "uom",               "fieldtype": "Link",    "options": "UOM",      "label": "UOM"},
    {"fieldname": "planned_start",     "fieldtype": "Date",    "label": "Planned Start"},
    {"fieldname": "col_break_2",       "fieldtype": "Column Break"},
    {"fieldname": "planned_end",       "fieldtype": "Date",    "label": "Planned End"},
    {"fieldname": "status",            "fieldtype": "Select",  "label": "Status",
      "options": "Draft\nMaterial Issued\nIn Production\nCompleted\nCancelled","default": "Draft","in_list_view": 1},
    {"fieldname": "section_materials", "fieldtype": "Section Break","label": "Raw Materials Issued"},
    {"fieldname": "materials",         "fieldtype": "Table",   "label": "Materials",  "options": "SM Supplier Work Order Material"},
    {"fieldname": "section_receipt",   "fieldtype": "Section Break","label": "Finished Goods Receipt"},
    {"fieldname": "received_qty",      "fieldtype": "Float",   "label": "Received Qty","read_only": 1},
    {"fieldname": "col_break_3",       "fieldtype": "Column Break"},
    {"fieldname": "scrap_qty",         "fieldtype": "Float",   "label": "Scrap Qty",  "read_only": 1},
    {"fieldname": "cost_sheet",        "fieldtype": "Link",    "options": "SM Subcontract Cost Sheet","label": "Cost Sheet","read_only": 1}
  ],
  "permissions": [
    {"role": "SM Admin",             "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Subcontract Manager","read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Viewer",            "read": 1}
  ]
}
