{
  "name": "SM Lot Tracking Log",
  "module": "Batch Traceability",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "LTL-.YYYY.-.#####",
  "fields": [
    {"fieldname": "batch_no",          "fieldtype": "Link",    "options": "Batch",      "label": "Batch / Lot",     "reqd": 1, "in_list_view": 1},
    {"fieldname": "item_code",         "fieldtype": "Link",    "options": "Item",       "label": "Item",            "in_list_view": 1},
    {"fieldname": "col_break_1",       "fieldtype": "Column Break"},
    {"fieldname": "event_type",        "fieldtype": "Select",  "label": "Event Type",
      "options": "Manufactured\nTransferred\nSold\nReturned\nRecalled\nExpired\nScrapped\nAdjusted",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "event_datetime",    "fieldtype": "Datetime","label": "Event Date/Time","reqd": 1},
    {"fieldname": "qty",               "fieldtype": "Float",   "label": "Qty",           "in_list_view": 1},
    {"fieldname": "uom",               "fieldtype": "Link",    "options": "UOM",        "label": "UOM"},
    {"fieldname": "from_warehouse",    "fieldtype": "Link",    "options": "Warehouse",  "label": "From Warehouse"},
    {"fieldname": "col_break_2",       "fieldtype": "Column Break"},
    {"fieldname": "to_warehouse",      "fieldtype": "Link",    "options": "Warehouse",  "label": "To Warehouse"},
    {"fieldname": "customer",          "fieldtype": "Link",    "options": "Customer",   "label": "Customer"},
    {"fieldname": "supplier",          "fieldtype": "Link",    "options": "Supplier",   "label": "Supplier"},
    {"fieldname": "voucher_type",      "fieldtype": "Data",    "label": "Voucher Type"},
    {"fieldname": "voucher_no",        "fieldtype": "Data",    "label": "Voucher No"},
    {"fieldname": "remarks",           "fieldtype": "Small Text","label": "Remarks"}
  ],
  "permissions": [
    {"role": "SM Admin",             "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "SM Quality Inspector", "read": 1, "write": 1},
    {"role": "SM Production Manager","read": 1},
    {"role": "SM Viewer",            "read": 1}
  ]
}
