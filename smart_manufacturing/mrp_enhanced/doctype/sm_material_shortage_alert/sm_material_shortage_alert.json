{
  "name": "SM Material Shortage Alert",
  "module": "MRP Enhanced",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "MSA-.YYYY.-.#####",
  "quick_entry": 1,
  "fields": [
    {"fieldname": "item_code",        "fieldtype": "Link",    "options": "Item",     "label": "Item",         "reqd": 1, "in_list_view": 1},
    {"fieldname": "warehouse",        "fieldtype": "Link",    "options": "Warehouse","label": "Warehouse",    "reqd": 1},
    {"fieldname": "col_break_1",      "fieldtype": "Column Break"},
    {"fieldname": "required_qty",     "fieldtype": "Float",   "label": "Required Qty","in_list_view": 1},
    {"fieldname": "available_qty",    "fieldtype": "Float",   "label": "Available Qty","in_list_view": 1},
    {"fieldname": "shortage_qty",     "fieldtype": "Float",   "label": "Shortage Qty","in_list_view": 1,"read_only": 1},
    {"fieldname": "required_by",      "fieldtype": "Date",    "label": "Required By", "in_list_view": 1},
    {"fieldname": "severity",         "fieldtype": "Select",  "label": "Severity",
      "options": "Critical\nHigh\nMedium\nLow", "in_list_view": 1},
    {"fieldname": "status",           "fieldtype": "Select",  "label": "Status",
      "options": "Open\nPO Raised\nResolved", "default": "Open", "in_list_view": 1},
    {"fieldname": "work_order",       "fieldtype": "Link",    "options": "Work Order","label": "Work Order"},
    {"fieldname": "po_reference",     "fieldtype": "Link",    "options": "Purchase Order","label": "PO Reference","read_only": 1}
  ],
  "permissions": [
    {"role": "SM Admin",   "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "SM Planner", "read": 1, "write": 1, "create": 1},
    {"role": "SM Viewer",  "read": 1}
  ]
}
