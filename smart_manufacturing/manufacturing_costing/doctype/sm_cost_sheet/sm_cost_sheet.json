{
  "name": "SM Cost Sheet",
  "module": "Manufacturing Costing",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "CS-.YYYY.-.#####",
  "title_field": "work_order",
  "fields": [
    {"fieldname": "work_order",         "fieldtype": "Link",     "options": "Work Order","label": "Work Order","reqd": 1, "in_list_view": 1},
    {"fieldname": "company",            "fieldtype": "Link",     "options": "Company",   "label": "Company",   "reqd": 1},
    {"fieldname": "col_break_1",        "fieldtype": "Column Break"},
    {"fieldname": "item_code",          "fieldtype": "Link",     "options": "Item",      "label": "Item",      "in_list_view": 1},
    {"fieldname": "currency",           "fieldtype": "Link",     "options": "Currency",  "label": "Currency",  "reqd": 1, "default": "USD"},
    {"fieldname": "status",             "fieldtype": "Select",   "label": "Status",
      "options": "Open\nIn Progress\nClosed\nCancelled", "default": "Open", "in_list_view": 1},
    {"fieldname": "section_qty",        "fieldtype": "Section Break", "label": "Quantities"},
    {"fieldname": "planned_qty",        "fieldtype": "Float",    "label": "Planned Qty"},
    {"fieldname": "actual_qty",         "fieldtype": "Float",    "label": "Actual Qty",  "read_only": 1},
    {"fieldname": "col_break_2",        "fieldtype": "Column Break"},
    {"fieldname": "scrap_qty",          "fieldtype": "Float",    "label": "Scrap Qty",   "read_only": 1},
    {"fieldname": "good_qty",           "fieldtype": "Float",    "label": "Good Qty",    "read_only": 1},
    {"fieldname": "section_std_cost",   "fieldtype": "Section Break", "label": "Standard Costs (Per Unit)"},
    {"fieldname": "std_material_cost",  "fieldtype": "Currency", "label": "Material Cost",  "options": "currency"},
    {"fieldname": "std_labor_cost",     "fieldtype": "Currency", "label": "Labor Cost",     "options": "currency"},
    {"fieldname": "col_break_3",        "fieldtype": "Column Break"},
    {"fieldname": "std_machine_cost",   "fieldtype": "Currency", "label": "Machine Cost",   "options": "currency"},
    {"fieldname": "std_overhead_cost",  "fieldtype": "Currency", "label": "Overhead Cost",  "options": "currency"},
    {"fieldname": "std_total_cost",     "fieldtype": "Currency", "label": "Total Standard Cost","options": "currency","read_only": 1},
    {"fieldname": "section_act_cost",   "fieldtype": "Section Break", "label": "Actual Costs"},
    {"fieldname": "act_material_cost",  "fieldtype": "Currency", "label": "Actual Material",   "options": "currency","read_only": 1},
    {"fieldname": "act_labor_cost",     "fieldtype": "Currency", "label": "Actual Labor",      "options": "currency","read_only": 1},
    {"fieldname": "col_break_4",        "fieldtype": "Column Break"},
    {"fieldname": "act_machine_cost",   "fieldtype": "Currency", "label": "Actual Machine",    "options": "currency","read_only": 1},
    {"fieldname": "act_overhead_cost",  "fieldtype": "Currency", "label": "Actual Overhead",   "options": "currency","read_only": 1},
    {"fieldname": "act_total_cost",     "fieldtype": "Currency", "label": "Total Actual Cost", "options": "currency","read_only": 1},
    {"fieldname": "section_variance",   "fieldtype": "Section Break", "label": "Variance Analysis"},
    {"fieldname": "material_variance",  "fieldtype": "Currency", "label": "Material Variance", "options": "currency","read_only": 1},
    {"fieldname": "labor_variance",     "fieldtype": "Currency", "label": "Labor Variance",    "options": "currency","read_only": 1},
    {"fieldname": "col_break_5",        "fieldtype": "Column Break"},
    {"fieldname": "machine_variance",   "fieldtype": "Currency", "label": "Machine Variance",  "options": "currency","read_only": 1},
    {"fieldname": "overhead_variance",  "fieldtype": "Currency", "label": "Overhead Variance", "options": "currency","read_only": 1},
    {"fieldname": "total_variance",     "fieldtype": "Currency", "label": "Total Variance",    "options": "currency","read_only": 1},
    {"fieldname": "variance_pct",       "fieldtype": "Percent",  "label": "Variance (%)",      "read_only": 1},
    {"fieldname": "section_details",    "fieldtype": "Section Break", "label": "Cost Detail Lines"},
    {"fieldname": "cost_lines",         "fieldtype": "Table",    "label": "Cost Lines",        "options": "SM Cost Line"}
  ],
  "permissions": [
    {"role": "SM Admin",          "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Cost Accountant","read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Production Manager","read": 1, "write": 1},
    {"role": "SM Viewer",         "read": 1}
  ]
}
