{
  "name": "Capacity Plan",
  "module": "Production Planning",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "CP-.YYYY.-.MM.-",
  "fields": [
    {"fieldname": "company",          "fieldtype": "Link",   "options": "Company",      "label": "Company",    "reqd": 1},
    {"fieldname": "workstation",      "fieldtype": "Link",   "options": "Workstation",  "label": "Workstation","reqd": 1, "in_list_view": 1},
    {"fieldname": "col_break_1",      "fieldtype": "Column Break"},
    {"fieldname": "from_date",        "fieldtype": "Date",   "label": "From Date",      "reqd": 1},
    {"fieldname": "to_date",          "fieldtype": "Date",   "label": "To Date",        "reqd": 1},
    {"fieldname": "section_capacity", "fieldtype": "Section Break", "label": "Capacity Details"},
    {"fieldname": "available_hours",  "fieldtype": "Float",  "label": "Available Hours/Day"},
    {"fieldname": "col_break_2",      "fieldtype": "Column Break"},
    {"fieldname": "efficiency_pct",   "fieldtype": "Percent","label": "Efficiency (%)", "default": "85"},
    {"fieldname": "effective_capacity","fieldtype": "Float", "label": "Effective Capacity (hrs)", "read_only": 1},
    {"fieldname": "section_load",     "fieldtype": "Section Break", "label": "Load Analysis"},
    {"fieldname": "capacity_details", "fieldtype": "Table", "label": "Capacity Details",
      "options": "Capacity Plan Detail"},
    {"fieldname": "section_summary",  "fieldtype": "Section Break", "label": "Summary"},
    {"fieldname": "total_planned_hours","fieldtype": "Float","label": "Total Planned Hours",  "read_only": 1},
    {"fieldname": "col_break_3",      "fieldtype": "Column Break"},
    {"fieldname": "utilization_pct",  "fieldtype": "Percent","label": "Utilization (%)",       "read_only": 1},
    {"fieldname": "is_overloaded",    "fieldtype": "Check",  "label": "Overloaded?",           "read_only": 1}
  ],
  "permissions": [
    {"role": "SM Admin",              "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Production Manager", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Planner",            "read": 1, "write": 1, "create": 1},
    {"role": "SM Viewer",             "read": 1}
  ]
}
