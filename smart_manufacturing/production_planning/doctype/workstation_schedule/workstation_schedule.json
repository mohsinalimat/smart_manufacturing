{
  "name": "Workstation Schedule",
  "module": "Production Planning",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "WS-.YYYY.-.MM.-",
  "fields": [
    {"fieldname": "workstation",       "fieldtype": "Link",    "options": "Workstation",  "label": "Workstation",     "reqd": 1, "in_list_view": 1},
    {"fieldname": "company",           "fieldtype": "Link",    "options": "Company",      "label": "Company",         "reqd": 1},
    {"fieldname": "col_break_1",       "fieldtype": "Column Break"},
    {"fieldname": "from_date",         "fieldtype": "Date",    "label": "From Date",      "reqd": 1},
    {"fieldname": "to_date",           "fieldtype": "Date",    "label": "To Date",        "reqd": 1},
    {"fieldname": "section_shifts",    "fieldtype": "Section Break","label": "Shift Schedule"},
    {"fieldname": "schedule_details",  "fieldtype": "Table",   "label": "Schedule Details","options": "Workstation Schedule Detail"},
    {"fieldname": "section_capacity",  "fieldtype": "Section Break","label": "Capacity Summary"},
    {"fieldname": "total_available_hrs","fieldtype": "Float",  "label": "Total Available Hrs","read_only": 1},
    {"fieldname": "col_break_2",       "fieldtype": "Column Break"},
    {"fieldname": "total_planned_hrs", "fieldtype": "Float",   "label": "Total Planned Hrs","read_only": 1},
    {"fieldname": "utilization_pct",   "fieldtype": "Percent", "label": "Utilization (%)", "read_only": 1}
  ],
  "permissions": [
    {"role": "SM Admin",              "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "SM Production Manager", "read": 1, "write": 1, "create": 1},
    {"role": "SM Planner",            "read": 1, "write": 1},
    {"role": "SM Viewer",             "read": 1}
  ]
}
