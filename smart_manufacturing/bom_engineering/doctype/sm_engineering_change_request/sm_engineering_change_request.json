{
  "name": "SM Engineering Change Request",
  "module": "BOM Engineering",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "ECR-.YYYY.-.#####",
  "title_field": "title",
  "fields": [
    {"fieldname": "title",           "fieldtype": "Data",    "label": "Title",       "reqd": 1, "in_list_view": 1},
    {"fieldname": "ecr_type",        "fieldtype": "Select",  "label": "Change Type",
      "options": "Design Change\nMaterial Substitution\nProcess Change\nDocumentation\nOther",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "col_break_1",     "fieldtype": "Column Break"},
    {"fieldname": "priority",        "fieldtype": "Select",  "label": "Priority",
      "options": "Critical\nHigh\nMedium\nLow", "default": "Medium"},
    {"fieldname": "status",          "fieldtype": "Select",  "label": "Status",
      "options": "Draft\nUnder Review\nApproved\nRejected\nImplemented\nClosed",
      "default": "Draft", "in_list_view": 1},
    {"fieldname": "section_bom",     "fieldtype": "Section Break","label": "Affected BOM"},
    {"fieldname": "bom",             "fieldtype": "Link",    "options": "BOM",   "label": "BOM",     "in_list_view": 1},
    {"fieldname": "current_revision","fieldtype": "Data",    "label": "Current Revision","read_only": 1},
    {"fieldname": "col_break_2",     "fieldtype": "Column Break"},
    {"fieldname": "new_revision",    "fieldtype": "Data",    "label": "New Revision"},
    {"fieldname": "effective_date",  "fieldtype": "Date",    "label": "Effective Date"},
    {"fieldname": "section_changes", "fieldtype": "Section Break","label": "Changes"},
    {"fieldname": "change_description","fieldtype": "Text Editor","label": "Change Description","reqd": 1},
    {"fieldname": "reason",          "fieldtype": "Text Editor","label": "Reason for Change"},
    {"fieldname": "section_items",   "fieldtype": "Section Break","label": "Item Changes"},
    {"fieldname": "item_changes",    "fieldtype": "Table",   "label": "Item Changes","options": "SM ECR Item Change"},
    {"fieldname": "section_approval","fieldtype": "Section Break","label": "Approval"},
    {"fieldname": "requested_by",    "fieldtype": "Link",    "options": "Employee","label": "Requested By"},
    {"fieldname": "col_break_3",     "fieldtype": "Column Break"},
    {"fieldname": "reviewed_by",     "fieldtype": "Link",    "options": "Employee","label": "Reviewed By"},
    {"fieldname": "approved_by",     "fieldtype": "Link",    "options": "User",   "label": "Approved By","read_only": 1},
    {"fieldname": "approval_date",   "fieldtype": "Date",    "label": "Approval Date","read_only": 1}
  ],
  "permissions": [
    {"role": "SM Admin",              "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Production Manager", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Planner",            "read": 1, "write": 1, "create": 1},
    {"role": "SM Viewer",             "read": 1}
  ]
}
