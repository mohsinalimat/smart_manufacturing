{
  "name": "SM CAPA",
  "module": "SM Quality Management",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "CAPA-.YYYY.-.#####",
  "title_field": "title",
  "fields": [
    {"fieldname": "title",              "fieldtype": "Data",    "label": "Title",              "reqd": 1, "in_list_view": 1},
    {"fieldname": "capa_type",          "fieldtype": "Select",  "label": "CAPA Type",
      "options": "Corrective\nPreventive", "reqd": 1, "in_list_view": 1},
    {"fieldname": "col_break_1",        "fieldtype": "Column Break"},
    {"fieldname": "priority",           "fieldtype": "Select",  "label": "Priority",
      "options": "Critical\nHigh\nMedium\nLow", "default": "Medium"},
    {"fieldname": "status",             "fieldtype": "Select",  "label": "Status",
      "options": "Open\nIn Progress\nVerification\nClosed\nCancelled", "default": "Open", "in_list_view": 1},
    {"fieldname": "section_origin",     "fieldtype": "Section Break", "label": "Origin"},
    {"fieldname": "source_type",        "fieldtype": "Select",  "label": "Source",
      "options": "Quality Inspection\nNCR\nCustomer Complaint\nInternal Audit\nOther"},
    {"fieldname": "source_reference",   "fieldtype": "Data",    "label": "Source Reference"},
    {"fieldname": "col_break_2",        "fieldtype": "Column Break"},
    {"fieldname": "identified_by",      "fieldtype": "Link",    "options": "Employee","label": "Identified By"},
    {"fieldname": "identified_date",    "fieldtype": "Date",    "label": "Identified Date"},
    {"fieldname": "section_description","fieldtype": "Section Break","label": "Problem Description"},
    {"fieldname": "problem_statement",  "fieldtype": "Text Editor","label": "Problem Statement","reqd": 1},
    {"fieldname": "root_cause",         "fieldtype": "Text Editor","label": "Root Cause Analysis"},
    {"fieldname": "section_actions",    "fieldtype": "Section Break","label": "Action Plan"},
    {"fieldname": "actions",            "fieldtype": "Table",   "label": "Actions",           "options": "SM CAPA Action"},
    {"fieldname": "section_verification","fieldtype": "Section Break","label": "Verification"},
    {"fieldname": "target_date",        "fieldtype": "Date",    "label": "Target Date"},
    {"fieldname": "col_break_3",        "fieldtype": "Column Break"},
    {"fieldname": "verified_by",        "fieldtype": "Link",    "options": "Employee","label": "Verified By"},
    {"fieldname": "verification_date",  "fieldtype": "Date",    "label": "Verification Date"},
    {"fieldname": "effectiveness",      "fieldtype": "Select",  "label": "Effectiveness",
      "options": "\nEffective\nPartially Effective\nNot Effective"}
  ],
  "permissions": [
    {"role": "SM Admin",             "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Quality Inspector", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Production Manager","read": 1, "write": 1},
    {"role": "SM Viewer",            "read": 1}
  ]
}
