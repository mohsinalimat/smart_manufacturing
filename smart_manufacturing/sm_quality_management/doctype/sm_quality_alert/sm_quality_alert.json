{
  "name": "SM Quality Alert",
  "module": "SM Quality Management",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "QA-.YYYY.-.#####",
  "quick_entry": 1,
  "fields": [
    {"fieldname": "alert_title",    "fieldtype": "Data",    "label": "Alert Title",  "reqd": 1, "in_list_view": 1},
    {"fieldname": "severity",       "fieldtype": "Select",  "label": "Severity",
      "options": "Critical\nHigh\nMedium\nLow", "default": "Medium", "in_list_view": 1},
    {"fieldname": "col_break_1",    "fieldtype": "Column Break"},
    {"fieldname": "work_order",     "fieldtype": "Link",    "options": "Work Order","label": "Work Order"},
    {"fieldname": "workstation",    "fieldtype": "Link",    "options": "Workstation","label": "Workstation"},
    {"fieldname": "item_code",      "fieldtype": "Link",    "options": "Item",      "label": "Item"},
    {"fieldname": "alert_message",  "fieldtype": "Text Editor","label": "Alert Message","reqd": 1},
    {"fieldname": "status",         "fieldtype": "Select",  "label": "Status",
      "options": "Open\nAcknowledged\nResolved", "default": "Open", "in_list_view": 1},
    {"fieldname": "resolved_by",    "fieldtype": "Link",    "options": "Employee",  "label": "Resolved By"},
    {"fieldname": "resolved_date",  "fieldtype": "Datetime","label": "Resolved At"}
  ],
  "permissions": [
    {"role": "SM Admin",             "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "SM Quality Inspector", "read": 1, "write": 1, "create": 1},
    {"role": "SM Production Manager","read": 1, "write": 1},
    {"role": "SM Viewer",            "read": 1}
  ]
}
