{
  "name": "SM Breakdown Log",
  "module": "Maintenance Equipment",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "naming_series:",
  "naming_series": "BRD-.YYYY.-.#####",
  "quick_entry": 1,
  "fields": [
    {"fieldname": "equipment",      "fieldtype": "Link",    "options": "SM Equipment","label": "Equipment","reqd": 1, "in_list_view": 1},
    {"fieldname": "breakdown_time", "fieldtype": "Datetime","label": "Breakdown Time","reqd": 1},
    {"fieldname": "col_break_1",    "fieldtype": "Column Break"},
    {"fieldname": "resumed_time",   "fieldtype": "Datetime","label": "Resumed Time"},
    {"fieldname": "downtime_hrs",   "fieldtype": "Float",   "label": "Downtime (hrs)","read_only": 1},
    {"fieldname": "failure_type",   "fieldtype": "Select",  "label": "Failure Type",
      "options": "Mechanical\nElectrical\nHydraulic\nPneumatic\nSoftware\nOther", "in_list_view": 1},
    {"fieldname": "symptom",        "fieldtype": "Small Text","label": "Symptom"},
    {"fieldname": "col_break_2",    "fieldtype": "Column Break"},
    {"fieldname": "root_cause",     "fieldtype": "Small Text","label": "Root Cause"},
    {"fieldname": "remedy",         "fieldtype": "Small Text","label": "Remedy Applied"},
    {"fieldname": "technician",     "fieldtype": "Link",    "options": "Employee","label": "Technician"},
    {"fieldname": "production_loss_qty","fieldtype": "Float","label": "Production Loss (qty)"},
    {"fieldname": "spare_parts_used","fieldtype": "Table",  "label": "Spare Parts Used","options": "SM Breakdown Spare Part"}
  ],
  "permissions": [
    {"role": "SM Admin",                "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1},
    {"role": "SM Maintenance Engineer", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "SM Production Manager",   "read": 1, "write": 1},
    {"role": "SM Viewer",               "read": 1}
  ]
}
