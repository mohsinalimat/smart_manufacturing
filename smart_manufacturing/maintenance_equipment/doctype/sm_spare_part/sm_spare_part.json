{
  "name": "SM Spare Part",
  "module": "Maintenance Equipment",
  "doctype": "DocType",
  "autoname": "field:item_code",
  "title_field": "item_code",
  "fields": [
    {"fieldname": "item_code",         "fieldtype": "Link",    "options": "Item",         "label": "Item",            "reqd": 1, "in_list_view": 1},
    {"fieldname": "item_name",         "fieldtype": "Data",    "label": "Item Name",      "read_only": 1, "in_list_view": 1, "fetch_from": "item_code.item_name"},
    {"fieldname": "col_break_1",       "fieldtype": "Column Break"},
    {"fieldname": "equipment",         "fieldtype": "Link",    "options": "SM Equipment", "label": "Equipment",       "in_list_view": 1},
    {"fieldname": "criticality",       "fieldtype": "Select",  "label": "Criticality",
      "options": "Critical\nHigh\nMedium\nLow", "default": "Medium", "in_list_view": 1},
    {"fieldname": "section_stock",     "fieldtype": "Section Break", "label": "Stock Details"},
    {"fieldname": "min_stock_qty",     "fieldtype": "Float",   "label": "Min Stock Qty"},
    {"fieldname": "current_stock",     "fieldtype": "Float",   "label": "Current Stock",  "read_only": 1},
    {"fieldname": "col_break_2",       "fieldtype": "Column Break"},
    {"fieldname": "reorder_qty",       "fieldtype": "Float",   "label": "Reorder Qty"},
    {"fieldname": "lead_time_days",    "fieldtype": "Int",     "label": "Lead Time (days)"},
    {"fieldname": "preferred_supplier","fieldtype": "Link",    "options": "Supplier",     "label": "Preferred Supplier"},
    {"fieldname": "warehouse",         "fieldtype": "Link",    "options": "Warehouse",    "label": "Warehouse"}
  ],
  "permissions": [
    {"role": "SM Admin",                "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "SM Maintenance Engineer", "read": 1, "write": 1, "create": 1},
    {"role": "SM Viewer",               "read": 1}
  ]
}
