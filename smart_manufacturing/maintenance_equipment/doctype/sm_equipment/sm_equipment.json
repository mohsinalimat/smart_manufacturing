{
  "name": "SM Equipment",
  "module": "Maintenance Equipment",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "EQ-.####",
  "title_field": "equipment_name",
  "image_field": "image",
  "fields": [
    {"fieldname": "equipment_name",   "fieldtype": "Data",    "label": "Equipment Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "equipment_type",   "fieldtype": "Select",  "label": "Type",
      "options": "Machine\nConveyor\nUtility\nTool\nVehicle\nOther", "in_list_view": 1},
    {"fieldname": "col_break_1",      "fieldtype": "Column Break"},
    {"fieldname": "workstation",      "fieldtype": "Link",    "options": "Workstation",  "label": "Workstation"},
    {"fieldname": "status",           "fieldtype": "Select",  "label": "Status",
      "options": "Active\nUnder Maintenance\nBreakdown\nRetired\nIdle", "default": "Active", "in_list_view": 1},
    {"fieldname": "image",            "fieldtype": "Attach Image","label": "Image"},
    {"fieldname": "section_details",  "fieldtype": "Section Break","label": "Equipment Details"},
    {"fieldname": "manufacturer",     "fieldtype": "Data",    "label": "Manufacturer"},
    {"fieldname": "model",            "fieldtype": "Data",    "label": "Model"},
    {"fieldname": "col_break_2",      "fieldtype": "Column Break"},
    {"fieldname": "serial_no",        "fieldtype": "Data",    "label": "Serial No"},
    {"fieldname": "purchase_date",    "fieldtype": "Date",    "label": "Purchase Date"},
    {"fieldname": "warranty_expiry",  "fieldtype": "Date",    "label": "Warranty Expiry"},
    {"fieldname": "section_metrics",  "fieldtype": "Section Break","label": "Runtime Metrics"},
    {"fieldname": "total_runtime_hrs","fieldtype": "Float",   "label": "Total Runtime (hrs)","read_only": 1},
    {"fieldname": "col_break_3",      "fieldtype": "Column Break"},
    {"fieldname": "last_service_date","fieldtype": "Date",    "label": "Last Service Date","read_only": 1},
    {"fieldname": "next_service_date","fieldtype": "Date",    "label": "Next Service Date","read_only": 1},
    {"fieldname": "pm_frequency_days","fieldtype": "Int",     "label": "PM Frequency (days)","default": "30"},
    {"fieldname": "section_specs",    "fieldtype": "Section Break","label": "Technical Specs"},
    {"fieldname": "specifications",   "fieldtype": "Table",   "label": "Specifications", "options": "SM Equipment Spec"}
  ],
  "permissions": [
    {"role": "SM Admin",                "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "SM Maintenance Engineer", "read": 1, "write": 1, "create": 1},
    {"role": "SM Viewer",               "read": 1}
  ]
}
